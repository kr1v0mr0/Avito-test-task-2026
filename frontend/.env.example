# Базовый URL backend (по умолчанию http://localhost:8080)
# VITE_API_BASE_URL=http://localhost:8080

# Модель Ollama (по умолчанию llama3)
# VITE_OLLAMA_MODEL=llama3

# Прямой URL Ollama (если не используете прокси Vite / nginx)
# VITE_OLLAMA_URL=http://127.0.0.1:11434

# Сборка с относительным прокси `/ollama` (docker-образ с nginx)
# VITE_OLLAMA_VIA_PROXY=true
